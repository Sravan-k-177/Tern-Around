ENVIRONMENT=development
FLASK_SECRET_KEY=change-me
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=tern_around

# Email verification (Brevo API)
BREVO_API_KEY=your-brevo-api-key
BREVO_SENDER_EMAIL=verified-sender@example.com
BREVO_SENDER_NAME=Tern-Around

# Twilio SMS Configuration (for phone number verification via OTP)
# Get these from https://www.twilio.com/console
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# Optional: used when users enter 10-digit local phone numbers (defaults to +91)
PHONE_DEFAULT_COUNTRY_CODE=+91
